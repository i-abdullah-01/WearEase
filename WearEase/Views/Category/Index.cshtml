@{
    ViewData["Title"] = "Product Details";
}

<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <!-- PRODUCT IMAGE -->
            <div class="col-md-6 mb-4 mb-md-0">
                <img src="~/images/Men/pexels-chloekalaartist-1043474.jpg"
                     class="img-fluid rounded shadow-sm"
                     style="height: 500px; object-fit: cover; width: 100%;"
                     alt="Men's Formal Shirt">
            </div>

            <!-- PRODUCT DETAILS -->
            <div class="col-md-6">
                <h2 class="fw-bold mb-3">Men's Casual Shirt</h2>
                <p class="text-muted mb-4">Stay stylish and comfortable with our premium cotton casual shirt, perfect for both formal and casual outings.</p>
                <h4 class="text-warning fw-bold mb-3">$25.00</h4>

                <!-- SIZE SELECTION -->
                <div class="mb-3">
                    <label class="fw-semibold">Select Size:</label>
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-outline-dark btn-sm">S</button>
                        <button class="btn btn-outline-dark btn-sm">M</button>
                        <button class="btn btn-outline-dark btn-sm">L</button>
                        <button class="btn btn-outline-dark btn-sm">XL</button>
                    </div>
                </div>

                <!-- QUANTITY -->
                <div class="mb-4">
                    <label class="fw-semibold">Quantity:</label>
                    <input type="number" value="1" min="1" class="form-control w-25 d-inline-block ms-2" />
                </div>

                <!-- ACTION BUTTONS -->
                <!-- ACTION BUTTONS -->
                <div class="d-flex gap-3">
                    <a href="/WearEase/Cart" class="btn btn-dark px-4">Add to Cart</a>
                    <a href="/WearEase/Cart" class="btn btn-warning text-dark px-4 fw-semibold">Buy Now</a>
                </div>


                <!-- ADDITIONAL INFO -->
                <div class="mt-5">
                    <h6 class="fw-bold mb-2">Product Details:</h6>
                    <ul class="text-muted">
                        <li>Material: 100% Cotton</li>
                        <li>Available Sizes: S, M, L, XL</li>
                        <li>Color: Sky Blue</li>
                        <li>Care: Machine Wash Cold</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

