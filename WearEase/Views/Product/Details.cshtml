                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-dark px-4">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                        <a asp-controller="Checkout"
                           asp-action="Index" class="btn btn-warning px-4 fw-semibold"
