@model IEnumerable<Product>
@{
    ViewData["Title"] = "Search Results";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <span>Search Results for: <span class="text-warning">"@ViewBag.SearchTerm"</span></span>
                    <span class="badge bg-secondary ms-2">@ViewBag.ResultCount found</span>
                }
            </h2>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-info">
                    @ViewBag.Message
                </div>
            }

            @if (!Model.Any())
            {
                <div class="alert alert-warning">
                    No products found matching your search criteria.
                    <a href="@Url.Action("Index")" class="alert-link">Browse all products</a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
                    @foreach (var product in Model)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 250px; object-fit: cover;">
                                <div class="card-body">
                                    <h5 class="card-title">@product.Name</h5>
                                    <p class="card-text text-muted">@product.Category.Name</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="h5 text-warning">$ @product.Price</span>
                                        <a href="@Url.Action("Details", new { id = product.Id })" class="btn btn-outline-warning btn-sm">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 text-center">
                    <a href="@Url.Action("Index")" class="btn btn-outline-dark">
                        <i class="bi bi-arrow-left"></i> Back to All Products
                    </a>
                </div>
            }
        </div>
    </div>
</div>