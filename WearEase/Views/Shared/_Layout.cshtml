@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WearEase</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WearEase.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-black shadow-sm sticky-top">
        <div class="container">

            <a class="navbar-brand fw-bold text-warning fs-4" asp-controller="WearEase" asp-action="Index">
                WearEase
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-auto">
                    <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="WearEase" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Product" asp-action="Index">Shop</a></li>
                    @* <a asp-controller="Product" asp-action="Index">Shop</a> *@


                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-semibold" data-bs-toggle="dropdown">Categories</a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-categoryId="7">Men</a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-categoryId="6">Women</a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Product"
                                   asp-action="Index"
                                   asp-route-categoryId="8">Kids</a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="WearEase" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="WearEase" asp-action="Contact">Contact</a></li>
                    

                </ul>
                <ul class ="navbar-nav me-auto mb-2 mb-lg-0 ms-auto">
                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Order" asp-action="MyOrders">My Orders</a>
                </li>
                </ul>
                @* <form class="d-flex mx-auto" method="get" asp-controller="WearEase" asp-action="Search">
                    <input class="form-control form-control-sm me-2" type="search" name="query" placeholder="Search products..." style="width: 280px;">
                    <button class="btn btn-warning btn-sm" type="submit"><i class="bi bi-search"></i></button>
                </form> *@
               @*  <div class="position-relative mx-auto" style="width: 280px;">
                    <input id="searchInput"
                           class="form-control form-control-sm"
                           type="search"
                           placeholder="Search products..." />

                    <div id="searchResults"
                         class="list-group position-absolute w-100 d-none"
                         style="z-index: 1000; top: 100%;">
                    </div>
                </div> *@
                <div class="position-relative mx-auto" style="width: 280px;">
                    <input id="searchInput"
                           class="form-control form-control-sm"
                           type="search"
                           placeholder="Search products..." />

                    <div id="searchResults"
                         class="list-group position-absolute w-100 d-none"
                         style="z-index: 1000; top: 100%;">
                    </div>
                </div>

                    <div id="searchResults"
                         class="list-group position-absolute w-100 d-none"
                         style="z-index: 1000; top: 100%;">
                    </div>
                </div>
                <div class="d-flex align-items-center ms-3">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Identity/Account/Login" class="me-3">
                            <button type="submit" class="btn btn-warning btn-sm fw-semibold">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="text-light me-3">
                            <i class="bi bi-person fs-5"></i>
                        </a>
                    }

                    <a asp-controller="Cart" class="text-light">
                        <i class="bi bi-cart fs-5"></i>
                    </a>
                    


                    


                    @* FIXED ADMIN CLAIM CHECK *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var user = await UserManager.GetUserAsync(User);

                        if (user != null)
                        {
                            var claims = await UserManager.GetClaimsAsync(user);

                            if (claims.Any(c => c.Type == "Role" && c.Value == "Admin"))
                            {
                                <li class="nav-item ms-3">
                                    <a class="nav-link text-warning fw-bold" href="/Admin/Index">
                                        <i class="fa fa-crown"></i> Admin Panel
                                    </a>
                                </li>
                            }
                        }
                    }
                </div>

            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-black text-white pt-5 pb-4 mt-5 border-top border-secondary">

        <div class="container text-md-left">
            <div class="row text-md-left">
                <!-- SHOP -->
                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Shop</h5>
                    <p><a href="/WearEase/Products" class="text-white text-decoration-none">Categories</a></p>
                    <p><a href="/WearEase/Products" class="text-white text-decoration-none">New Arrivals</a></p>
                    <p><a href="/WearEase/Products" class="text-white text-decoration-none">Sale</a></p>
                </div>

                <!-- INFORMATION -->
                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Information</h5>
                    <p><a href="/WearEase/About" class="text-white text-decoration-none">About Us</a></p>
                    <p><a href="/WearEase/Contact" class="text-white text-decoration-none">Contact Us</a></p>
                    <p><a href="#" class="text-white text-decoration-none">Our Blog</a></p>
                </div>

                <!-- CUSTOMER SERVICE -->
                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Customer Service</h5>
                    <p><a href="#" class="text-white text-decoration-none">FAQ</a></p>
                    <p><a href="#" class="text-white text-decoration-none">Shipping & Returns</a></p>
                    <p><a href="#" class="text-white text-decoration-none">Store Guide</a></p>
                </div>

                <!-- PAYMENT & SOCIAL -->
                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Payment Methods</h5>
                    <div class="d-flex mb-3">
                        <img src="~/images/Bnners/cc-visa-brands-solid-full.svg" alt="Visa" width="45" class="me-2">
                        <img src="~/images/Bnners/card.png" alt="Mastercard" width="45" class="me-2">
                        <img src="~/images/Bnners/paypal.png" alt="PayPal" width="45">
                    </div>
                    <h5 class="text-uppercase mb-3 font-weight-bold text-warning">Follow Us</h5>
                    <div>
                        <a href="#" class="text-white me-3"><i class="bi bi-facebook fs-4"></i></a>
                        <a href="#" class="text-white me-3"><i class="bi bi-instagram fs-4"></i></a>
                        <a href="#" class="text-white me-3"><i class="bi bi-twitter fs-4"></i></a>
                        <a href="#" class="text-white"><i class="bi bi-pinterest fs-4"></i></a>
                    </div>
                </div>
            </div>

            <hr class="mt-4 mb-3 text-white">

            <div class="row align-items-center">
                <div class="col-md-8 col-lg-8">
                    <p class="text-center text-md-start mb-0">
                        © 2025 <span class="text-warning">WearEase</span>. All rights reserved.
                    </p>
                </div>
                <div class="col-md-4 col-lg-4 text-center text-md-end">
                    <a href="#" class="text-white text-decoration-none me-3">Privacy Policy</a>
                    <a href="#" class="text-white text-decoration-none">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
