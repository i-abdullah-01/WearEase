
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    

    <div class="container-fluid">
        <div class="row">

            <!-- ⭐ SIDEBAR -->
            <nav class="col-md-3 col-lg-2 d-md-block bg-dark text-white sidebar collapse p-3  navbar-expand-lg"
                 id="sidebarMenu">

                <h4 class="text-center text-warning mb-4">Admin Panel</h4>
                @* <ul class="nav flex-column">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-white" href="#" id="notifDropdown"
                       role="button" data-bs-toggle="dropdown">
                        🔔 <span id="notifCount" class="badge bg-danger">0</span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end" id="notifList"
                        style="width:300px; max-height:300px; overflow:auto;">
                        <li class="dropdown-header">New Orders</li>
                    </ul>
                </li>
                </ul> *@
                <ul class="nav flex-column">

                    <!-- ⭐ DASHBOARD (Admin only) -->
                    @if (User.HasClaim("Role", "Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/Index#dashboard">
                                <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                            </a>
                        </li>
                    }

                    <!-- ⭐ Add Product (ManageProducts permission) -->
                    @if (User.HasClaim("Permission", "ManageProducts"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white"  href="#" onclick="showForm('addForm')"  >
                                <i class="fas fa-plus-circle me-2"></i> Add Product
                            </a>
                        </li>
                    }

                    <!-- ⭐ Products Section -->
                    @if (User.HasClaim("Permission", "ManageProducts"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/Index#productsSection">
                                <i class="fas fa-boxes me-2"></i> Products
                            </a>
                        </li>
                    }

                    <!-- ⭐ Orders Section -->
                    @if (User.HasClaim("Permission", "ManageOrders"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/AdminOrder/Index#ordersSection">
                                <i class="fas fa-shopping-cart me-2"></i>Recent Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/Index#ordersSection">
                                <i class="fas fa-shopping-cart me-2"></i> Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Admin" asp-action="Index1">
                                <i class="fas fa-shopping-cart me-2"></i> Orders Per Day
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="AdminOrder" asp-action="Index" class="btn btn-dark">
                                <i class="fas fa-boxes me-2"></i> Manage Orders
                            </a>
                        </li>
                    }

                    <!-- ⭐ Customers only visible to Admin -->
                    @if (User.HasClaim("Role", "Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Admin/Index#customersSection">
                                <i class="fas fa-users me-2"></i> Customers
                            </a>
                        </li>
                    }

                </ul>

                <hr class="border-secondary">

                <!-- ⭐ Logout -->
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-danger fw-bold"
                           asp-area="Identity" asp-page="/Account/Logout">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Logout
                        </a>
                    </li>
                </ul>

            </nav>

            <!-- ⭐ MAIN CONTENT -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .build();

        let notifCount = 0;

        connection.on("NewOrderPlaced", function (orderId, customer) {
            notifCount++;
            document.getElementById("notifCount").innerText = notifCount;

            const li = document.createElement("li");
            li.innerHTML = `
                <a class="dropdown-item">
                    🛒 Order #${orderId} by ${customer}
                </a>`;
            document.getElementById("notifList").appendChild(li);
        });

        connection.start()
            .catch(err => console.error(err));
    </script>

</body>
</html>
 