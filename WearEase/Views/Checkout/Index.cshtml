 @model WearEase.Models.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold mb-4 text-center">Checkout</h2>

        <form asp-controller="Order" asp-action="PlaceOrder" method="post">
            <div class="row">

                <!-- BILLING -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="fw-bold mb-3">Billing & Shipping</h5>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                                </div>
                                <div class="col-md-6">
                                    <input asp-for="Email" class="form-control" placeholder="Email" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <input asp-for="Phone" class="form-control" placeholder="Phone" />
                                </div>
                                <div class="col-md-6">
                                    <input asp-for="City" class="form-control" placeholder="City" />
                                </div>
                            </div>

                            <textarea asp-for="Address" class="form-control mb-3" placeholder="Address"></textarea>

                            <div class="row">
                                <div class="col-md-6">
                                    <input asp-for="PostalCode" class="form-control" placeholder="Postal Code" />
                                </div>
                                <div class="col-md-6">
                                    <select asp-for="Country" class="form-select">
                                        <option>Pakistan</option>
                                        <option>USA</option>
                                        <option>UK</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SUMMARY -->
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-body">
                            <h5 class="fw-bold mb-3">Order Summary</h5>

                            @foreach (var item in Model.Cart.CartItems)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>
                                        @item.Product.Name
                                        <small class="text-muted">(Qty: @item.Quantity)</small>
                                    </span>


                                    <span>$@(item.Product.Price* item.Quantity)</span>
                                </div>
                            }

                            <hr />

                            <div class="d-flex justify-content-between">
                                <span>Subtotal</span>
                                <span>$@Model.SubTotal</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span>Shipping</span>
                                <span>$@Model.Shipping</span>
                            </div>

                            <div class="d-flex justify-content-between fw-bold mt-2">
                                <span>Total</span>
                                <span>$@Model.Total</span>
                            </div>
                        </div>
                    </div>


                    <h5 class="fw-bold mt-4">Payment Method</h5>

                    <div class="form-check">
                        <input asp-for="PaymentMethod" class="form-check-input"
                               type="radio" value="COD" checked id="cod" />
                        <label class="form-check-label" for="cod">
                            Cash on Delivery
                        </label>
                    </div>

                    <div class="form-check mt-2">
                        <input asp-for="PaymentMethod" class="form-check-input"
                               type="radio" value="Card" id="card" />
                        <label class="form-check-label" for="card">
                            Credit / Debit Card
                        </label>
                    </div>

                    <div id="cardFields" class="mt-3" style="display:none;">
                        <input asp-for="CardNumber" class="form-control mb-2" placeholder="Card Number" />
                        <input asp-for="Expiry" class="form-control mb-2" placeholder="Expiry MM/YY" />
                        <input asp-for="CVV" class="form-control" placeholder="CVV" />
                    </div>

                    <span class="text-danger">@Html.ValidationSummary()</span>

                    <button type="submit" class="btn btn-dark w-100 mt-3">
                        Place Order
                    </button>


                        @* <button type="submit" class="btn btn-dark w-100 mt-3">
                            Place Order
                        </button> *@

                   

                    
                </div>

            </div>
        </form>
    </div>
</section>
 
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const cardRadio = document.getElementById("card");
        const codRadio = document.getElementById("cod");
        const cardFields = document.getElementById("cardFields");

        // Default state on page load
        if (codRadio.checked) {
            cardFields.style.display = "none";
        }

        cardRadio.addEventListener("change", () => {
            cardFields.style.display = "block";
        });

        codRadio.addEventListener("change", () => {
            cardFields.style.display = "none";
        });
    </script>
}
