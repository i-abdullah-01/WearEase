            <!-- Add Product Form -->
            <section id="addProduct" class="form-section">
                <div class="form-container">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="section-title">Add New Product</h3>
                        <button class="btn btn-outline-secondary btn-sm" onclick="showSection('dashboard')">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </button>
                    </div>
                    <form method="post" asp-action="AddProduct" enctype="multipart/form-data" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Product Name</label>
                            <input type="text" class="form-control" name="Name" required placeholder="Enter product name">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Price ($)</label>
                            <input type="number" class="form-control" name="Price" step="0.01" required placeholder="0.00">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Category</label>
                            <select class="form-select" name="CategoryId" required>
                                <option value="">Select Category</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Product Image</label>
                            <input type="file" class="form-control" name="ImageFile" accept="image/*" required>
                            <div class="form-text">Upload product image (JPG, PNG, JPEG)</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" rows="4" name="Description" placeholder="Enter product description"></textarea>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 py-3">
                                <i class="fas fa-save me-2"></i>Save Product
                            </button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- Products List -->
            <section id="productsSection" class="form-section">
                <div class="table-container">
                    <div class="table-header">
                        <h5 class="table-title">Products Management</h5>
                        <div class="d-flex gap-2">
                            <div class="search-box">
                                <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="Search products...">
                                <i class="fas fa-search"></i>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" onclick="showSection('dashboard')">
                                <i class="fas fa-arrow-left me-1"></i> Back
                            </button>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="data-table" id="productsTable">
                            <thead>
                                <tr>
                                    <th>Image</th>
                                    <th>Product</th>
                                    <th>Category</th>
                                    <th>Price</th>
                                    <th>Description</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in products)
                                {
                                    <tr>
                                        <td>
                                            <img src="@p.ImageUrl" width="60" height="60" class="rounded border" alt="@p.Name">
                                        </td>
                                        <td>
                                            <strong>@p.Name</strong>
                                        </td>
                                        <td>@p.Category?.Name</td>
                                        <td class="fw-bold text-success">$@p.Price</td>
                                        <td>
                                            <div class="text-truncate" style="max-width: 200px;">
                                                @p.Description
                                            </div>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="EditProduct" asp-route-id="@p.Id"
