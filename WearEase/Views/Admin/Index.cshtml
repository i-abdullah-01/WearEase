                                <div class="display-6 fw-bold text-success">@approvedOrders</div>
                                <div class="text-muted">Approved</div>
                            </div>
                            <div class="col-md-3 text-center">
                                <div class="display-6 fw-bold text-primary">@deliveredOrders</div>
                                <div class="text-muted">Delivered</div>
