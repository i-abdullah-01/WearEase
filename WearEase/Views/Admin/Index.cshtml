                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="showSection('categoriesSection')">
                        <i class="fas fa-tags nav-icon"></i>
                        <span class="sidebar-text">Categories</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="showSection('ordersSection')">
                        <i class="fas fa-shopping-cart nav-icon"></i>
                        <span class="sidebar-text">Orders</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#" onclick="showSection('analyticsSection')">
                        <i class="fas fa-chart-line nav-icon"></i>
                        <span class="sidebar-text">Analytics</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-danger" asp-area="Identity" asp-page="/Account/Logout">
                        <i class="fas fa-sign-out-alt nav-icon"></i>
                        <span class="sidebar-text">Logout</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <header class="admin-header">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="header-title">
                            <h1 id="pageTitle">Dashboard Overview</h1>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="header-actions justify-content-end">
                          

                            <div class="user-profile">
                                <div class="user-avatar">
                                    @User.Identity?.Name?[0]
                                </div>
                                <div class="user-info d-none d-md-block">
                                    <div class="user-name">@User.Identity?.Name</div>
                                    <div class="user-role">Administrator</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <div class="content-area">
            <!-- Dashboard Section -->
            <section id="dashboard" class="form-section active">
                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card primary">
                        <div class="stat-content">
                            <div class="stat-numbers">
                                <h3>@totalProducts</h3>
                                <div class="stat-title">Total Products</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-box"></i>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card success">
                        <div class="stat-content">
                            <div class="stat-numbers">
                                <h3>@totalOrders</h3>
                                <div class="stat-title">Total Orders</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card warning">
                        <div class="stat-content">
                            <div class="stat-numbers">
                                <h3>$@totalRevenue</h3>
                                <div class="stat-title">Total Revenue</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card danger">
                        <div class="stat-content">
                            <div class="stat-numbers">
                                <h3>@pendingOrders</h3>
                                <div class="stat-title">Pending Orders</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="quick-actions">
                    <h3 class="section-title">Quick Actions</h3>
                    <div class="actions-grid">
                        <div class="action-card" onclick="showSection('addProduct')">
                            <div class="action-icon">
                                <i class="fas fa-plus"></i>
                            </div>
                            <h5>Add Product</h5>
                            <p>Add new product to store</p>
                        </div>

                        <div class="action-card" onclick="showSection('productsSection')">
                            <div class="action-icon">
                                <i class="fas fa-edit"></i>
                            </div>
                            <h5>Manage Products</h5>
                            <p>Edit existing products</p>
                        </div>

                        <div class="action-card" onclick="showSection('ordersSection')">
                            <div class="action-icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            <h5>View Orders</h5>
                            <p>Process customer orders</p>
                        </div>

                        <div class="action-card" onclick="showSection('categoriesSection')">
                            <div class="action-icon">
                                <i class="fas fa-tags"></i>
                            </div>
                            <h5>Categories</h5>
                            <p>Manage product categories</p>
                        </div>

                        <div class="action-card" onclick="showSection('analyticsSection')">
                            <div class="action-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <h5>Analytics</h5>
                            <p>View sales analytics</p>
                        </div>
                    </div>
                </div>

                <!-- Recent Orders -->
                <div class="table-container">
                    <div class="table-header">
                        <h5 class="table-title">Recent Orders</h5>
                        <button class="btn btn-primary btn-sm" onclick="showSection('ordersSection')">
                            View All
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in orders.Take(5))
                                {
                                    <tr>
                                        <td><strong>#@order.Id</strong></td>
                                        <td>@order.CustomerId</td>
                                        <td class="fw-bold">$@order.TotalAmount</td>
                                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge @(order.Status == "Approved" ? "badge-approved" : order.Status == "Delivered" ? "badge-delivered" : "badge-pending")">
                                                @order.Status
                                            </span>
                                        </td>
                                        <td>
                                            @if (order.Status == "Pending")
                                            {
                                                <form asp-action="Approve" method="post" style="display: inline;">
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <button class="btn btn-success btn-sm">Approve</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
