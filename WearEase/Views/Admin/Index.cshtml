                                                    <form asp-action="Deliver" method="post" style="display: inline;">
                                                        <input type="hidden" name="id" value="@order.Id" />
                                                        <button type="submit" class="btn btn-primary btn-sm">
                                                            <i class="fas fa-truck me-1"></i>Deliver
                                                        </button>
