                    <div class="table-header">
                        <h5 class="table-title">Categories Management</h5>
                        <div class="d-flex gap-2">
                            <div class="search-box">
                                <input type="text" id="categorySearch" class="form-control form-control-sm" placeholder="Search categories...">
                                <i class="fas fa-search"></i>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" onclick="showSection('dashboard')">
                                <i class="fas fa-arrow-left me-1"></i> Back
                            </button>
                        </div>
