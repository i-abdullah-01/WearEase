                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="DeleteProduct" asp-route-id="@p.Id"
                                                   class="btn btn-outline-danger"
                                                   onclick="return confirm('Are you sure you want to delete this product?')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
