                                <input type="text" id="orderSearch" class="form-control form-control-sm" placeholder="Search orders...">
                                <i class="fas fa-search"></i>
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" onclick="showSection('dashboard')">
                                <i class="fas fa-arrow-left me-1"></i> Back
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="data-table" id="ordersTable">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Total Amount</th>
                                    <th>Customer</th>
                                    <th>Order Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in orders)
                                {
                                    <tr>
                                        <td><strong>#@order.Id</strong></td>
                                        <td class="fw-bold">$@order.TotalAmount</td>
                                        <td>@order.CustomerId</td>
                                        <td>@order.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                        <td>
                                            <span class="badge @(order.Status == "Approved" ? "badge-approved" : order.Status == "Delivered" ? "badge-delivered" : "badge-pending")">
                                                @order.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                @if (order.Status == "Pending")
                                                {
                                                    <form asp-action="Approve" method="post" style="display: inline;">
                                                        <input type="hidden" name="id" value="@order.Id" />
                                                        <button type="submit" class="btn btn-success btn-sm">
                                                            <i class="fas fa-check me-1"></i>Approve
                                                        </button>
                                                    </form>
                                                }
                                                @if (order.Status == "Approved")
