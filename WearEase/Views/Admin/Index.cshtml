                                <input type="text" name="Name" class="form-control" placeholder="Enter category name" required>
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-plus me-2"></i>Add Category
                                </button>
                            </div>
