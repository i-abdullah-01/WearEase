                                </div>
                                <div class="chart-wrapper">
                                    <canvas id="salesChart"></canvas>
                                </div>
                            </div>

                            <!-- Orders Chart -->
                            <div class="chart-container">
                                <div class="chart-header mb-3">
                                    <h6 class="chart-title fw-bold">Orders Overview</h6>
                                </div>
                                <div class="chart-wrapper">
                                    <canvas id="ordersChart"></canvas>
                                </div>
