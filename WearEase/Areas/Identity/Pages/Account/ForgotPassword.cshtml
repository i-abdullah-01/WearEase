@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="container-fluid min-vh-100 d-flex justify-content-center align-items-center position-relative p-0">

    <!-- Background Image -->
    <img src="~/images/Bnners/Fashion.webp"
         class="position-absolute w-100 h-100"
         style="object-fit: cover; filter: brightness(60%);" />

    <div class="card shadow-lg p-4" style="max-width: 430px; width: 100%; position: relative; z-index: 5;">
        <h2 class="text-center mb-3">Forgot Password</h2>
        <p class="text-center text-muted">Enter your email and we will send you a password reset link.</p>
        <hr />

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                <label asp-for="Input.Email"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-dark w-100 py-2">Send Reset Link</button>

            <p class="text-center mt-3">
                <a asp-page="./Login">Back to Login</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
